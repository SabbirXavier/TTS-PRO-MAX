rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isEmail(email) { return isSignedIn() && request.auth.token.email.lower() == email.lower(); }
    
    function isAdmin() { 
      return isSignedIn() && (
        isEmail('nemesis.developers.org@gmail.com') ||
        isEmail('dcpromoidse@gmail.com') ||
        (exists(/databases/$(database)/documents/settings/platform) && 
         request.auth.token.email in get(/databases/$(database)/documents/settings/platform).data.allowedAdmins)
      );
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Validation Blueprints
    function isValidStreamer(data) {
      return data.displayName is string && data.displayName.size() <= 100 &&
             data.username is string && data.username.size() <= 50 &&
             data.role in ['streamer', 'admin'] &&
             data.subscriptionActive is bool &&
             (data.get('planId', 'standard') is string) &&
             (data.get('gateways', []) is list);
    }

    function isValidDonation(data) {
      return data.streamerId is string && isValidId(data.streamerId) &&
             data.amount is number && data.amount > 0 &&
             data.donorName is string && data.donorName.size() <= 100 &&
             data.currency is string && data.currency.size() <= 10;
    }

    function isValidWidget(data) {
      return data.streamerId is string && isValidId(data.streamerId) &&
             data.type in ['alert', 'goal', 'ticker'] &&
             data.config is map;
    }

    function isValidPlan(data) {
      return data.name is string && data.name.size() <= 50 &&
             data.price is number &&
             data.features is map;
    }

    // 0.1 Settings Collection
    match /settings/platform {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // 0.2 Subscription Plans Collection
    match /plans/{planId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // 1. Streamers Collection
    match /streamers/{streamerId} {
      allow read: if true;
      allow create: if isVerified() && request.auth.uid == streamerId && isValidStreamer(incoming());
      allow update: if isAdmin() || (
        isVerified() && 
        request.auth.uid == streamerId && 
        isValidStreamer(incoming()) &&
        incoming().role == existing().role // Users cannot change their own role
      );
      allow delete: if isAdmin() || (isVerified() && request.auth.uid == streamerId);
    }

    // 2. Donations Collection
    match /donations/{donationId} {
      allow read: if true;
      allow create: if isValidDonation(incoming());
      allow update: if (
        isAdmin() || 
        (isVerified() && existing().streamerId == request.auth.uid)
      ) && incoming().amount == existing().amount; // Prevent changing amounts
      allow delete: if isAdmin();
    }

    // 3. Widgets Collection
    match /widgets/{widgetId} {
      allow read: if true;
      allow create: if isVerified() && incoming().streamerId == request.auth.uid && isValidWidget(incoming());
      allow update: if isAdmin() || (
        isVerified() && 
        existing().streamerId == request.auth.uid && 
        incoming().streamerId == existing().streamerId // Prevent changing owner
      );
      allow delete: if isAdmin() || (isVerified() && existing().streamerId == request.auth.uid);
    }
  }
}
